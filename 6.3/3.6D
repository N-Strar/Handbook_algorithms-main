import sys

def main() -> None:
    data = sys.stdin.buffer.read().split()
    if not data:
        return
    it = iter(data)
    n = int(next(it))
    k = int(next(it))
    coords = [int(next(it)) for _ in range(n)]
    coords.sort()
    ans = k                     # самый левый – только к потолку
    for i in range(1, n):
        dist = coords[i] - coords[i - 1]
        ans += min(k, dist * dist)
    print(ans)

if __name__ == "__main__":
    main()
