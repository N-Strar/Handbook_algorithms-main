def solve():
    n, S = map(int, input().split())
    a = list(map(int, input().split()))
    a.sort()
    left = 0
    right = n - 1
    count = 0
    while left < right:
        if a[left] + a[right] <= S:
            count += right - left
            left += 1
        else:
            right -= 1
    print(count)

if __name__ == "__main__":
    solve()
