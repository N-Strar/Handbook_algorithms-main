n = int(input())
adj = [list(map(int, input().split())) for _ in range(n)]

# Матрица достижимости (копируем матрицу смежности)
reach = [row[:] for row in adj]

# Алгоритм Флойда-Уоршелла для поиска достижимости
for k in range(n):
    for i in range(n):
        for j in range(n):
            if reach[i][k] and reach[k][j]:
                reach[i][j] = 1

# Вывод
for row in reach:
    print(' '.join(map(str, row)))
